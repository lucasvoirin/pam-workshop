 &lt;audio id="audio-demo1" controls style="width:100%"&gt;&lt;/audio&gt;
&lt;/div&gt;

&lt;script src="https://unpkg.com/wavesurfer.js@7/dist/wavesurfer.min.js"&gt;&lt;/script&gt;
&lt;script src="https://unpkg.com/wavesurfer.js@7/dist/plugins/spectrogram.min.js"&gt;&lt;/script&gt;

&lt;script&gt;
(function() {
 const id = 'demo1';
 const SpectrogramPlugin = WaveSurfer.Spectrogram;

 const container = document.getElementById('ws-container-' + id);
 const audioEl = document.getElementById('audio-' + id);

 const observer = new ResizeObserver((entries) =&gt; {
 const width = entries[0].contentRect.width;

 if (width &gt; 100) {
 observer.disconnect();

 const ws = WaveSurfer.create({
 container: '#waveform-' + id,
 media: audioEl, 
 waveColor: '#4F8EF7',
 progressColor: '#1a56db',
 height: 80 ,
 normalize: true,
 fillParent: true,

 plugins: [
 SpectrogramPlugin.create({
 container: '#spectrogram-' + id,
 labels: true,
 fftSamples: 1024,
 noverlap: 512,
 windowFunc: 'hann',
 scale: 'linear',
 height: 150 ,
 }),
 ],
 });

 
 ws.load('\/pam-workshop\/audio\/clips.wav');
 }
 });

 observer.observe(container);
})();
&lt;/script&gt;


